generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model categories {
  categoryID   Int     @id @default(autoincrement()) @db.UnsignedInt
  categoryName String  @db.VarChar(255)
  description  String? @db.Text
  gigs         gigs[]
}

model conversation_participants {
  conversationParticipantsID Int           @id @default(autoincrement()) @db.UnsignedInt
  userID                     Int           @db.UnsignedInt
  conversationID             Int           @db.UnsignedInt
  users                      users         @relation(fields: [userID], references: [userID], onDelete: Cascade, onUpdate: Restrict, map: "conversation_participants_ibfk_1")
  conversations              conversations @relation(fields: [conversationID], references: [conversationID], onDelete: Cascade, onUpdate: Restrict, map: "conversation_participants_ibfk_2")

  @@index([conversationID], map: "conversationID")
  @@index([userID], map: "userID")
}

model conversations {
  conversationID            Int                         @id @default(autoincrement()) @db.UnsignedInt
  orderID                   Int?                        @db.UnsignedInt
  created_at                DateTime?                   @default(now()) @db.DateTime(0)
  updated_at                DateTime?                   @db.DateTime(0)
  conversation_participants conversation_participants[]
  orders                    orders?                     @relation(fields: [orderID], references: [orderID], onUpdate: Restrict, map: "conversations_ibfk_1")
  messages                  messages[]

  @@index([orderID], map: "orderID")
}

model freelancer_profiles {
  userID       Int      @id @db.UnsignedInt
  slogan       String?  @db.VarChar(255)
  descriptions String?  @db.Text
  level        Int?     @default(1) @db.TinyInt
  rating       Decimal? @default(0.0) @db.Decimal(2, 1)
  reviewCount  Int?     @default(0)
  users        users    @relation(fields: [userID], references: [userID], onDelete: Cascade, onUpdate: Restrict, map: "freelancer_profiles_ibfk_1")
}

model freelancer_skills {
  userID  Int    @db.UnsignedInt
  skillID Int    @db.UnsignedInt
  users   users  @relation(fields: [userID], references: [userID], onDelete: Cascade, onUpdate: Restrict, map: "freelancer_skills_ibfk_1")
  skills  skills @relation(fields: [skillID], references: [skillID], onDelete: Cascade, onUpdate: Restrict, map: "freelancer_skills_ibfk_2")

  @@id([userID, skillID])
  @@index([skillID], map: "skillID")
}

model gig_packages {
  packageID   Int      @id @default(autoincrement()) @db.UnsignedInt
  title       String   @db.VarChar(255)
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  deliveryDay Int
  revision    Int     @default(0)
  gigID       Int      @db.UnsignedInt
  gigs        gigs     @relation(fields: [gigID], references: [gigID], onDelete: Cascade, onUpdate: Restrict, map: "gig_packages_ibfk_1")
  orders      orders[]

  @@index([gigID], map: "gigID")
}

model gigs {
  gigID        Int      @id @default(autoincrement()) @db.UnsignedInt
  title        String   @db.VarChar(255)
  description  String   @db.Text
  img_url      String?  @db.VarChar(255)

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  categoryID   Int      @db.UnsignedInt
  freelancerID Int      @db.UnsignedInt

  gig_packages gig_packages[]
  categories   categories @relation(fields: [categoryID], references: [categoryID])
  users        users @relation(fields: [freelancerID], references: [userID])
  orders       orders[]
}

model messages {
  messageID      Int           @id @default(autoincrement()) @db.UnsignedInt
  senderID       Int           @db.UnsignedInt
  content        String        @db.Text
  read_at        DateTime?     @db.DateTime(0)
  created_at     DateTime?     @default(now()) @db.DateTime(0)
  conversationID Int           @db.UnsignedInt
  users          users         @relation(fields: [senderID], references: [userID], onUpdate: Restrict, map: "messages_ibfk_1")
  conversations  conversations @relation(fields: [conversationID], references: [conversationID], onDelete: Cascade, onUpdate: Restrict, map: "messages_ibfk_2")

  @@index([conversationID], map: "conversationID")
  @@index([senderID], map: "senderID")
}

model orders {
  orderID                          Int             @id @default(autoincrement()) @db.UnsignedInt
  buyerID                          Int             @db.UnsignedInt
  freelancerID                     Int             @db.UnsignedInt
  gigID                            Int             @db.UnsignedInt
  packageID                        Int             @db.UnsignedInt
  price                            Decimal         @db.Decimal(10, 2)
  serviceFee                       Decimal?        @default(0.00) @db.Decimal(10, 2)
  totalAmount                      Decimal         @db.Decimal(10, 2)
  status                           Int?            @default(1) @db.TinyInt
  created_at                       DateTime?       @default(now()) @db.DateTime(0)
  delivered_at                     DateTime?       @db.DateTime(0)
  updated_at                       DateTime?       @db.DateTime(0)
  conversations                    conversations[]
  buyer                            users           @relation("BuyerOrders", fields: [buyerID], references: [userID], onUpdate: Restrict, map: "orders_ibfk_1")
  freelancer                       users           @relation("FreelancerOrders", fields: [freelancerID], references: [userID], onUpdate: Restrict, map: "orders_ibfk_2")
  gigs                             gigs            @relation(fields: [gigID], references: [gigID], onUpdate: Restrict, map: "orders_ibfk_3")
  gig_packages                     gig_packages    @relation(fields: [packageID], references: [packageID], onUpdate: Restrict, map: "orders_ibfk_4")
  reviews                          reviews[]

  @@index([buyerID], map: "buyerID")
  @@index([freelancerID], map: "freelancerID")
  @@index([gigID], map: "gigID")
  @@index([packageID], map: "packageID")
}

model reviews {
  reviewID                        Int       @id @default(autoincrement()) @db.UnsignedInt
  orderID                         Int       @db.UnsignedInt
  reviewerID                      Int       @db.UnsignedInt
  revieweeID                      Int       @db.UnsignedInt
  rating                          Int       @db.TinyInt
  comment                         String?   @db.Text
  created_at                      DateTime? @default(now()) @db.DateTime(0)
  orders                          orders    @relation(fields: [orderID], references: [orderID], onDelete: Cascade, onUpdate: Restrict, map: "reviews_ibfk_1")
  reviewer users @relation("Reviewer", fields: [reviewerID], references: [userID])
  reviewee users @relation("Reviewee", fields: [revieweeID], references: [userID])

  @@index([orderID], map: "orderID")
  @@index([revieweeID], map: "revieweeID")
  @@index([reviewerID], map: "reviewerID")
}

model roles {
  roleID     Int          @id @default(autoincrement()) @db.UnsignedInt
  roleName   String       @unique(map: "roleName") @db.VarChar(100)
  user_roles user_roles[]
}

model skills {
  skillID           Int                 @id @default(autoincrement()) @db.UnsignedInt
  skillName         String              @unique(map: "skillName") @db.VarChar(255)
  freelancer_skills freelancer_skills[]
}

model user_roles {
  userRoleID Int   @id @default(autoincrement()) @db.UnsignedInt
  userID     Int   @db.UnsignedInt
  roleID     Int   @db.UnsignedInt
  users      users @relation(fields: [userID], references: [userID], onDelete: Cascade, onUpdate: Restrict, map: "user_roles_ibfk_1")
  roles      roles @relation(fields: [roleID], references: [roleID], onDelete: Cascade, onUpdate: Restrict, map: "user_roles_ibfk_2")

  @@index([roleID], map: "roleID")
  @@index([userID], map: "userID")
  
  @@unique([userID, roleID])
  
}

model users {
  userID                            Int                         @id @default(autoincrement()) @db.UnsignedInt
  name                              String                      @db.VarChar(255)
  email                             String                      @unique(map: "email") @db.VarChar(255)
  password                          String                      @db.VarChar(255)
  avatar                            String?                     @db.VarChar(255)
  bio                               String?                     @db.Text
  created_at                        DateTime?                   @default(now()) @db.DateTime(0)
  conversation_participants         conversation_participants[]
  freelancer_profiles               freelancer_profiles?
  freelancer_skills                 freelancer_skills[]
  gigs                              gigs[]
  messages                          messages[]
  buyerOrders                       orders[]                    @relation("BuyerOrders")
  freelancerOrders                  orders[]                    @relation("FreelancerOrders")
  reviewsGiven                      reviews[]                    @relation("Reviewer")
  reviewsReceived                   reviews[]                   @relation("Reviewee")
  user_roles                        user_roles[]
}
